generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── TENANT (un studio) ──────────────────────────────────
model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Stripe Connect — nullable car rempli après l'onboarding
  stripeAccountId      String? // acct_xxx — ID du compte Connect du studio
  stripeOnboardingDone Boolean @default(false)

  users    User[]
  artists  Artist[]
  flashes  Flash[]
  bookings Booking[]
}

// ── USER ────────────────────────────────────────────────
model User {
  id        String   @id @default(uuid())
  tenantId  String
  email     String   @unique
  password  String
  role      Role     @default(CLIENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Stripe Customer — créé à la première réservation du client
  stripeCustomerId String? // cus_xxx — permet de réutiliser les moyens de paiement

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  artist   Artist?
  bookings Booking[]
}

enum Role {
  OWNER
  ARTIST
  CLIENT
}

// ── ARTIST ──────────────────────────────────────────────
model Artist {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String   @unique
  bio       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
  flashes Flash[]
}

// ── FLASH ────────────────────────────────────────────────
model Flash {
  id          String      @id @default(uuid())
  tenantId    String
  artistId    String
  title       String
  description String?
  imageUrl    String
  price       Int // en centimes (ex: 5000 = 50€)
  status      FlashStatus @default(AVAILABLE)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  artist  Artist   @relation(fields: [artistId], references: [id])
  booking Booking?
}

enum FlashStatus {
  AVAILABLE
  BOOKED
  DONE
}

// ── BOOKING ──────────────────────────────────────────────
model Booking {
  id            String        @id @default(uuid())
  tenantId      String
  clientId      String
  flashId       String        @unique
  scheduledAt   DateTime
  status        BookingStatus @default(PENDING)
  depositAmount Int // en centimes — 30% du prix du flash

  // Stripe Payment — nullable car rempli après le paiement
  stripePaymentIntentId String? // pi_xxx — pour tracker et capturer le paiement
  depositPaid           Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  client User   @relation(fields: [clientId], references: [id])
  flash  Flash  @relation(fields: [flashId], references: [id])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}
