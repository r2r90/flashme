generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── TENANT (un studio) ──────────────────────────────────
model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  artists   Artist[]
  flashes   Flash[]
  bookings  Booking[]
}

// ── USER ────────────────────────────────────────────────
model User {
  id        String   @id @default(uuid())
  tenantId  String
  email     String   @unique
  password  String
  role      Role     @default(CLIENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  artist    Artist?
  bookings  Booking[]
}

enum Role {
  OWNER
  ARTIST
  CLIENT
}

// ── ARTIST ──────────────────────────────────────────────
model Artist {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String   @unique
  bio       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
  flashes   Flash[]
}

// ── FLASH ────────────────────────────────────────────────
model Flash {
  id          String      @id @default(uuid())
  tenantId    String
  artistId    String
  title       String
  description String?
  imageUrl    String
  price       Int         // en centimes
  status      FlashStatus @default(AVAILABLE)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  artist      Artist      @relation(fields: [artistId], references: [id])
  booking     Booking?
}

enum FlashStatus {
  AVAILABLE
  BOOKED
  DONE
}

// ── BOOKING ──────────────────────────────────────────────
model Booking {
  id            String        @id @default(uuid())
  tenantId      String
  clientId      String
  flashId       String        @unique
  scheduledAt   DateTime
  status        BookingStatus @default(PENDING)
  depositAmount Int           // en centimes
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  client        User          @relation(fields: [clientId], references: [id])
  flash         Flash         @relation(fields: [flashId], references: [id])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}